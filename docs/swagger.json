{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Echo and server statistics API",
        "title": "Hello World Tasks API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/echo": {
            "get": {
                "description": "Accepts a message via query param (GET) or JSON body (POST) and returns it unchanged",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "echo"
                ],
                "summary": "Echo a message",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Message to echo (GET)",
                        "name": "message",
                        "in": "query"
                    },
                    {
                        "description": "Message to echo (POST)",
                        "name": "body",
                        "in": "body",
                        "schema": {
                            "$ref": "#/definitions/handler.EchoRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.EchoResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "description": "Accepts a message via query param (GET) or JSON body (POST) and returns it unchanged",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "echo"
                ],
                "summary": "Echo a message",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Message to echo (GET)",
                        "name": "message",
                        "in": "query"
                    },
                    {
                        "description": "Message to echo (POST)",
                        "name": "body",
                        "in": "body",
                        "schema": {
                            "$ref": "#/definitions/handler.EchoRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.EchoResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/stats": {
            "get": {
                "description": "Returns UTC server time, OS memory usage (total, in use, in-use %), and Go runtime heap stats",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "stats"
                ],
                "summary": "Server statistics",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.StatsResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.EchoRequest": {
            "description": "Echo request payload",
            "type": "object",
            "required": [
                "message"
            ],
            "properties": {
                "message": {
                    "type": "string",
                    "example": "hello world"
                }
            }
        },
        "handler.EchoResponse": {
            "description": "Echo response envelope",
            "type": "object",
            "properties": {
                "echo": {
                    "type": "string",
                    "example": "hello world"
                }
            }
        },
        "handler.ErrorResponse": {
            "description": "Standard error envelope",
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "invalid input"
                }
            }
        },
        "handler.GoMemStats": {
            "description": "Go runtime memory statistics",
            "type": "object",
            "properties": {
                "heap_alloc_bytes": {
                    "type": "integer",
                    "example": 2097152
                },
                "heap_in_use_bytes": {
                    "type": "integer",
                    "example": 3145728
                },
                "total_alloc_bytes": {
                    "type": "integer",
                    "example": 10485760
                }
            }
        },
        "handler.StatsResponse": {
            "description": "Server and runtime statistics",
            "type": "object",
            "properties": {
                "go_mem": {
                    "$ref": "#/definitions/handler.GoMemStats"
                },
                "server_time_utc": {
                    "type": "string",
                    "example": "2026-04-10T12:00:00Z"
                },
                "sys_mem": {
                    "$ref": "#/definitions/handler.SysMemStats"
                }
            }
        },
        "handler.SysMemStats": {
            "description": "Operating system memory statistics",
            "type": "object",
            "properties": {
                "total_bytes": {
                    "type": "integer",
                    "example": 17179869184
                },
                "used_bytes": {
                    "type": "integer",
                    "example": 8589934592
                },
                "used_percent": {
                    "type": "number",
                    "example": 50
                }
            }
        }
    }
}